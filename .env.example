# Copy this file to .env for local development.
# The real .env file is gitignored and must never be committed.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-side only for Supabase Edge Functions.
# Set these with `supabase secrets set`.
# Never pass these values to Flutter or commit real keys.
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local function test override.
SUPABASE_FUNCTION_URL=http://127.0.0.1:54321/functions/v1/analyze_cat_photo
